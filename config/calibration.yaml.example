%YAML:1.0
---
# Example camera calibration. Produced by OpenCV's calibrateCamera tutorial.
# Replace these values with your phone's actual calibration.
# Copy this file to config/calibration.yaml when you have real values.

image_width: 1280
image_height: 720

camera_matrix: !!opencv-matrix
   rows: 3
   cols: 3
   dt: d
   data: [ 1.2e+03, 0., 6.4e+02,
           0., 1.2e+03, 3.6e+02,
           0., 0., 1. ]

dist_coeffs: !!opencv-matrix
   rows: 1
   cols: 5
   dt: d
   data: [ 0., 0., 0., 0., 0. ]
